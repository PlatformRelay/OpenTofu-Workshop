# .env.example — copy to .env and (optionally) `source` it, or let awslocal
# read these. These are DUMMY credentials: LocalStack accepts any value and
# never talks to real AWS. Never put real AWS keys here.
#
#   cp .env.example .env
#   set -a; . ./.env; set +a     # export them into your shell (optional)

# Dummy credentials — LocalStack ignores their value but the AWS SDK/CLI
# requires them to be set to *something*.
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
AWS_REGION=us-east-1

# Point every AWS SDK / CLI call at LocalStack instead of real AWS.
# `awslocal` sets this for you; exporting it also makes plain `aws` and the
# OpenTofu AWS provider target LocalStack.
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ENDPOINT_URL_S3=http://localhost:4566

# Convenience for scripts that build service URLs.
LOCALSTACK_ENDPOINT=http://localhost:4566
